# Kaimon test runner — spawned as a subprocess, prints structured output for parser.
# Args: project_path [pattern] [verbose_level]
import Pkg
import TOML

project_path = ARGS[1]
pattern = length(ARGS) >= 2 ? ARGS[2] : ""
verbose_level = length(ARGS) >= 3 ? parse(Int, ARGS[3]) : 1

# Save the REAL stdout now, before any test can rebind `Base.stdout` (e.g. an eval
# capture mux). All TEST_RUNNER control markers go through this saved handle so the
# parent's result parser keeps receiving them regardless of what the tests do to
# `Base.stdout` — otherwise a test that leaves stdout rebound truncates the report.
const _RUNNER_OUT = stdout
println(_RUNNER_OUT, "TEST_RUNNER: START project=$(basename(project_path))")
flush(_RUNNER_OUT)

# ── Activate test environment ─────────────────────────────────────────────
# Build a throwaway temp env and `develop` the project under test into it, so its
# FULL dependency tree resolves into the manifest — including path dependencies
# and THEIR transitive deps. A bare `push!(LOAD_PATH, project_path)` only makes the
# main package importable; it does NOT record a path-dep's deps in the active
# manifest, so a path-dep that gains a new (e.g. stdlib) dependency fails to
# precompile in the test subprocess. (Regression from git 996cd1c, which dropped
# the `develop`; restored here without mutating the tracked test/Project.toml.)
main_toml = TOML.parsefile(joinpath(project_path, "Project.toml"))
test_project = joinpath(project_path, "test", "Project.toml")

Pkg.activate(mktempdir())
try
    Pkg.develop(Pkg.PackageSpec(path = project_path); io = devnull)
catch e
    println("TEST_RUNNER: WARN develop failed: $(first(sprint(showerror, e), 120))")
end

# Test-only deps: prefer test/Project.toml [deps]; else the legacy
# [extras]/[targets] layout in the main Project.toml.
test_deps = Dict{String,Any}()
if isfile(test_project)
    merge!(test_deps, get(TOML.parsefile(test_project), "deps", Dict()))
else
    extras = get(main_toml, "extras", Dict())
    for name in get(get(main_toml, "targets", Dict()), "test", String[])
        test_deps[name] = get(extras, name, nothing)
    end
end
delete!(test_deps, get(main_toml, "name", ""))   # never re-add the project itself

for (name, uuid) in test_deps
    try
        if uuid isa AbstractString
            Pkg.add(Pkg.PackageSpec(; name, uuid = Base.UUID(uuid)); io = devnull)
        else
            Pkg.add(name; io = devnull)
        end
    catch e
        println("TEST_RUNNER: WARN could not add $name: $(first(sprint(showerror, e), 120))")
    end
end

try
    Pkg.instantiate(; io = devnull)
catch e
    println("TEST_RUNNER: WARN instantiate failed: $(first(sprint(showerror, e), 120))")
end

# Keep the main project on LOAD_PATH so test files can `using` its own direct deps
# (e.g. ReTest) that aren't declared in the test environment.
push!(LOAD_PATH, project_path)

flush(stdout)

# ── Patch Test.jl for structured output ───────────────────────────────────
# Force verbose=true and emit TESTSET_START / TESTSET_DONE lines so the
# TUI can show real-time incremental results.
import Test

_testset_depth = Ref(0)

let _w = Base.get_world_counter()
    @eval function Test.push_testset(ts::Test.DefaultTestSet)
        ts.verbose = true
        $_testset_depth[] += 1
        println($_RUNNER_OUT, "TEST_RUNNER: TESTSET_START name=", ts.description)
        flush($_RUNNER_OUT)
        return Base.invoke_in_world($_w, Test.push_testset, ts)
    end
end

let _w2 = Base.get_world_counter()
    # Forward arbitrary kwargs (e.g. `print_results`) instead of hardcoding a
    # signature — Test.finish's keywords have drifted across Julia versions, and we
    # must match whatever the caller passes and hand it straight to the original.
    @eval function Test.finish(ts::Test.DefaultTestSet; kwargs...)
        # Always keep depth balanced (push_testset incremented it); only the marker
        # emission is guarded, so a drift in Test's count internals can't break the
        # actual run — the summary-table scraper still recovers the totals.
        $_testset_depth[] -= 1
        _depth = max(0, $_testset_depth[])
        try
            _tc = Test.get_test_counts(ts)
            _p = getproperty(_tc, :passes) + getproperty(_tc, :cumulative_passes)
            _f = getproperty(_tc, :fails) + getproperty(_tc, :cumulative_fails)
            _e = getproperty(_tc, :errors) + getproperty(_tc, :cumulative_errors)
            println($_RUNNER_OUT, "TEST_RUNNER: TESTSET_DONE",
                " pass=", _p, " fail=", _f, " error=", _e,
                " total=", _p + _f + _e, " depth=", _depth,
                " name=", ts.description)
            flush($_RUNNER_OUT)
        catch
        end

        return Base.invoke_in_world($_w2, Test.finish, ts; kwargs...)
    end
end

# ── Run tests ─────────────────────────────────────────────────────────────
runtests_path = joinpath(project_path, "test", "runtests.jl")
exit_code = 0

try
    cd(project_path)

    old_args = copy(ARGS)
    empty!(ARGS)
    !isempty(pattern) && push!(ARGS, pattern)

    try
        include(runtests_path)
    finally
        empty!(ARGS)
        append!(ARGS, old_args)
    end

    println(_RUNNER_OUT, "TEST_RUNNER: DONE status=passed")
catch e
    global exit_code = 1
    _is_test_failure = e isa Test.TestSetException
    if e isa LoadError
        _is_test_failure = e.error isa Test.TestSetException
    end
    if !_is_test_failure
        println(_RUNNER_OUT, "TEST_RUNNER: ERROR $(first(sprint(showerror, e), 500))")
        println(stderr, sprint(showerror, e, catch_backtrace()))
    end
    println(_RUNNER_OUT, "TEST_RUNNER: DONE status=failed")
end

flush(_RUNNER_OUT)
flush(stderr)
exit(exit_code)
